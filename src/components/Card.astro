---
import {
  MessageSquare, Brain, Bot, Image, Mic, Layout, Globe,
  Laptop, Terminal, User, Server, Settings, Shield, Database,
  ExternalLink
} from '@lucide/astro';

interface Props {
  name: string;
  description: string;
  url?: string;
  tags?: string[];
  icon?: string;
}

const { name, description, url, tags = [], icon = 'globe' } = Astro.props;

const iconMap: Record<string, any> = {
  'message-square': MessageSquare,
  'brain': Brain,
  'bot': Bot,
  'image': Image,
  'mic': Mic,
  'layout': Layout,
  'globe': Globe,
  'laptop': Laptop,
  'terminal': Terminal,
  'user': User,
  'server': Server,
  'settings': Settings,
  'shield': Shield,
  'database': Database,
};

const IconComponent = iconMap[icon] || Globe;

// Assign a color theme based on name hashes to make the card icons look colorful like the screenshot
const colors = [
  'text-pink-500 bg-pink-500/10 border-pink-500/20',
  'text-blue-500 bg-blue-500/10 border-blue-500/20',
  'text-purple-500 bg-purple-500/10 border-purple-500/20',
  'text-emerald-500 bg-emerald-500/10 border-emerald-500/20',
  'text-amber-500 bg-amber-500/10 border-amber-500/20',
  'text-cyan-500 bg-cyan-500/10 border-cyan-500/20',
];
const colorIndex = name.charCodeAt(0) % colors.length;
const iconColors = colors[colorIndex];
---

<div class="card glass-panel glass-panel-hover overflow-hidden rounded-2xl transition-all duration-300">
  <div class="card-body p-6 flex flex-col justify-between h-full gap-4">
    <div>
      <!-- Icon & Title -->
      <div class="flex items-center gap-3.5">
        <div class={`p-2.5 rounded-xl border flex items-center justify-center shrink-0 ${iconColors}`}>
          <IconComponent class="w-5 h-5" />
        </div>
        <h3 class="text-lg font-semibold text-neutral-100 group-hover:text-white transition-colors">
          {name}
        </h3>
      </div>
      
      <!-- Description -->
      <p class="text-sm text-neutral-400 mt-4 leading-relaxed line-clamp-3">
        {description}
      </p>
    </div>

    <!-- Tags and Action -->
    <div class="flex flex-col gap-3.5 mt-2">
      <!-- Tags -->
      {tags.length > 0 && (
        <div class="flex items-center gap-2">
          <span class="text-[10px] font-bold text-neutral-500 uppercase tracking-wider shrink-0">Tags:</span>
          <div class="flex flex-wrap gap-1.5">
            {tags.map((tag) => (
              <span class="badge badge-sm bg-neutral-800/80 border-neutral-700 text-neutral-300 rounded px-2">
                {tag}
              </span>
            ))}
          </div>
        </div>
      )}

      <!-- Link -->
      {url && (
        <a 
          href={url} 
          target="_blank" 
          rel="noopener noreferrer" 
          class="btn btn-sm btn-outline border-neutral-700 hover:border-pink-500/50 hover:bg-pink-500/5 text-neutral-300 hover:text-white rounded-lg flex items-center justify-between w-full mt-1.5"
        >
          <span>Visit Site</span>
          <ExternalLink class="w-3.5 h-3.5 ml-1 opacity-70" />
        </a>
      )}
    </div>
  </div>
</div>
