---
import '../styles/global.css';
import { Search, Moon, Sun, Sparkles, BookOpen, Layers } from '@lucide/astro';
import PagefindConfig from 'astro-pagefind/components/PagefindConfig.astro';

interface Props {
  title: string;
  description?: string;
  pagefindIgnore?: boolean;
}

const { title, description = "Roleplay AI Hub - A directory for Roleplay AI Models, Frontends, and Tools", pagefindIgnore = false } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Meta Tags -->
    <title>{title} | Roleplay AI Hub</title>
    <meta name="description" content={description} />
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <!-- Theme Script -->
    <script is:inline>
      const getTheme = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return 'dark';
      };
      document.documentElement.setAttribute('data-theme', getTheme());
    </script>

    <!-- Pagefind Config integration -->
    <PagefindConfig preload={true} />
  </head>
  <body class="bg-base-300 text-base-content min-h-screen flex flex-col font-sans selection:bg-pink-500/30 selection:text-white" data-pagefind-ignore={pagefindIgnore ? "all" : undefined}>
    
    <!-- Navbar -->
    <header class="sticky top-0 z-50 w-full border-b border-base-content/10 bg-base-300/80 backdrop-blur-lg">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between gap-4">
        
        <!-- Logo -->
        <div class="flex items-center gap-6 shrink-0">
          <a href="/" class="flex items-center gap-2 group">
            <span class="p-1.5 rounded-lg bg-gradient-to-tr from-pink-500 to-purple-600 text-white shadow-lg shadow-pink-500/20 group-hover:scale-105 transition-all duration-300">
              <Sparkles class="w-4 h-4" />
            </span>
            <span class="font-outfit font-extrabold text-xl tracking-tight bg-gradient-to-r from-base-content via-base-content/90 to-base-content/60 bg-clip-text text-transparent group-hover:text-base-content transition-all">
              Roleplay AI<span class="text-pink-500 font-medium"> Hub</span>
            </span>
            <!-- v0.0.1 Badge -->
            <span class="text-[9px] font-semibold bg-base-100 border border-base-content/10 text-base-content/70 rounded px-1.5 py-0.5 ml-1 self-center">
              v0.0.1
            </span>
          </a>
        </div>

        <!-- Search Bar -->
        <div class="hidden md:block max-w-sm w-full mx-auto">
          <pagefind-searchbox id="global-search" placeholder="Search resources..."></pagefind-searchbox>
        </div>

        <!-- Navigation Links & Icons -->
        <nav class="flex items-center gap-1 sm:gap-4 shrink-0">
          <!-- Text Links -->
          <div class="hidden sm:flex items-center gap-1.5 text-sm font-medium text-base-content/70">
            <a href="/ai-models" class="px-2.5 py-1.5 rounded-lg hover:text-base-content hover:bg-base-content/5 transition-all duration-300 flex items-center gap-1">
              <Layers class="w-3.5 h-3.5 opacity-70" /> Models
            </a>
            <a href="/frontends" class="px-2.5 py-1.5 rounded-lg hover:text-base-content hover:bg-base-content/5 transition-all duration-300 flex items-center gap-1">
              <BookOpen class="w-3.5 h-3.5 opacity-70" /> UIs
            </a>
            <a href="/tools" class="px-2.5 py-1.5 rounded-lg hover:text-base-content hover:bg-base-content/5 transition-all duration-300 flex items-center gap-1">
              <span class="text-xs">🔧</span> Tools
            </a>
          </div>

          <!-- Divider -->
          <div class="hidden sm:block h-4 w-px bg-base-content/10 mx-1"></div>

          <!-- Social Icons & Theme Toggle -->
          <div class="flex items-center gap-1 sm:gap-2">
            <!-- Theme Toggle -->
            <button id="theme-toggle" class="p-2 rounded-xl text-base-content/70 hover:text-base-content hover:bg-base-content/5 transition-all duration-300" aria-label="Theme toggle">
              <Moon class="w-4 h-4 theme-icon-moon" />
              <Sun class="w-4 h-4 theme-icon-sun" />
            </button>
            
            <!-- Github -->
            <a 
              href="https://github.com/Bitti09/roleplayaihub" 
              target="_blank" 
              rel="noopener noreferrer" 
              class="p-2 rounded-xl text-base-content/70 hover:text-base-content hover:bg-base-content/5 transition-all duration-300"
              aria-label="GitHub link"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
                <path d="M9 18c-4.51 2-5-2-7-2" />
              </svg>
            </a>
          </div>
        </nav>
      </div>
      
      <!-- WIP Alert Bar -->
      <div class="border-t border-base-content/10 bg-gradient-to-r from-pink-500/10 via-purple-500/5 to-transparent text-xs py-2 text-center text-base-content/80">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-center gap-2 flex-wrap">
          <span class="inline-flex items-center justify-center px-1.5 py-0.5 text-[9px] font-extrabold uppercase tracking-wider rounded bg-pink-500/20 border border-pink-500/30 text-pink-400 font-outfit">
            WIP
          </span>
          <span class="text-base-content/80 text-[11px] sm:text-xs">
            This directory is a work in progress. Currently, only the <a href="/ai-models" class="text-pink-400 hover:text-pink-300 font-semibold underline underline-offset-2 hover:underline-offset-4 transition-all">AI Models</a> section contains real data.
          </span>
        </div>
      </div>
    </header>

    <!-- Main Content Area -->
    <main class="flex-grow">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-base-content/10 bg-base-200 py-8 mt-16 text-center text-xs text-base-content/60">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col items-center gap-2">
        <p>Made with 💖 for the AI community</p>
        <p class="opacity-70">&copy; {new Date().getFullYear()} Roleplay AI Hub. Built with Astro & DaisyUI.</p>
        <p class="opacity-50 text-[10px] mt-1.5">This site does not host any copyrighted files. All links point to external resources.</p>
      </div>
    </footer>

    <!-- Theme Toggle Script -->
    <script>
      const themeToggle = document.getElementById('theme-toggle');
      themeToggle?.addEventListener('click', () => {
        const currentTheme = document.documentElement.getAttribute('data-theme');
        const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', newTheme);
        localStorage.setItem('theme', newTheme);
      });
    </script>
  </body>
</html>
