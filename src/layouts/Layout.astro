---
import '../styles/global.css';
import { Search, Moon, Sparkles, BookOpen, Layers } from '@lucide/astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "RPAI Hub - The ultimate directory for Roleplay AI Models, Frontends, and Tools" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Meta Tags -->
    <title>{title} | RPAI Hub</title>
    <meta name="description" content={description} />
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-[#0c0c0e] text-neutral-100 min-h-screen flex flex-col font-sans selection:bg-pink-500/30 selection:text-white">
    
    <!-- Navbar -->
    <header class="sticky top-0 z-50 w-full border-b border-white/5 bg-[#0c0c0e]/80 backdrop-blur-lg">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between gap-4">
        
        <!-- Logo -->
        <div class="flex items-center gap-6 shrink-0">
          <a href="/" class="flex items-center gap-2 group">
            <span class="p-1.5 rounded-lg bg-gradient-to-tr from-pink-500 to-purple-600 text-white shadow-lg shadow-pink-500/20 group-hover:scale-105 transition-all duration-300">
              <Sparkles class="w-4 h-4" />
            </span>
            <span class="font-outfit font-extrabold text-xl tracking-tight bg-gradient-to-r from-white via-neutral-100 to-neutral-400 bg-clip-text text-transparent group-hover:text-white transition-all">
              RPAI<span class="text-pink-500 font-medium">Hub</span>
            </span>
          </a>
        </div>

        <!-- Search Bar (FMHY style with Ctrl K shortcut) -->
        <div class="hidden md:flex relative max-w-sm w-full mx-auto">
          <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
            <Search class="h-4 w-4 text-neutral-500" />
          </div>
          <input
            type="search"
            id="global-search"
            placeholder="Search resources..."
            class="w-full rounded-xl bg-neutral-900/60 pl-9 pr-12 py-1.5 text-sm text-neutral-200 border border-neutral-800 placeholder-neutral-500 focus:outline-none focus:ring-1 focus:ring-pink-500/50 focus:border-pink-500/50 transition-all duration-300"
          />
          <div class="absolute inset-y-0 right-0 flex items-center pr-3">
            <kbd class="pointer-events-none inline-flex h-5 select-none items-center gap-0.5 rounded border border-neutral-800 bg-neutral-950 px-1.5 font-mono text-[10px] font-medium text-neutral-500">
              <span class="text-xs">Ctrl</span>K
            </kbd>
          </div>
        </div>

        <!-- Navigation Links & Icons -->
        <nav class="flex items-center gap-1 sm:gap-4 shrink-0">
          <!-- Text Links -->
          <div class="hidden sm:flex items-center gap-1.5 text-sm font-medium text-neutral-400">
            <a href="/ai-models" class="px-2.5 py-1.5 rounded-lg hover:text-white hover:bg-white/5 transition-all duration-300 flex items-center gap-1">
              <Layers class="w-3.5 h-3.5 opacity-70" /> Models
            </a>
            <a href="/frontends" class="px-2.5 py-1.5 rounded-lg hover:text-white hover:bg-white/5 transition-all duration-300 flex items-center gap-1">
              <BookOpen class="w-3.5 h-3.5 opacity-70" /> UIs
            </a>
            <a href="/tools" class="px-2.5 py-1.5 rounded-lg hover:text-white hover:bg-white/5 transition-all duration-300 flex items-center gap-1">
              <span class="text-xs">🔧</span> Tools
            </a>
          </div>

          <!-- Divider -->
          <div class="hidden sm:block h-4 w-px bg-white/10 mx-1"></div>

          <!-- Social Icons & Theme Toggle -->
          <div class="flex items-center gap-1 sm:gap-2">
            <!-- Theme Icon (Static aesthetic) -->
            <button class="p-2 rounded-xl text-neutral-400 hover:text-white hover:bg-white/5 transition-all duration-300" aria-label="Theme toggle">
              <Moon class="w-4 h-4" />
            </button>
            
            <!-- Github -->
            <a 
              href="https://github.com" 
              target="_blank" 
              rel="noopener noreferrer" 
              class="p-2 rounded-xl text-neutral-400 hover:text-white hover:bg-white/5 transition-all duration-300"
              aria-label="GitHub link"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
                <path d="M9 18c-4.51 2-5-2-7-2" />
              </svg>
            </a>

            <!-- Discord -->
            <a 
              href="https://discord.com" 
              target="_blank" 
              rel="noopener noreferrer" 
              class="p-2 rounded-xl text-neutral-400 hover:text-white hover:bg-white/5 transition-all duration-300"
              aria-label="Discord link"
            >
              <svg class="w-4 h-4" viewBox="0 0 127.14 96.36" fill="currentColor">
                <path d="M107.7,8.07A105.15,105.15,0,0,0,77.26,0a77.19,77.19,0,0,0-3.3,6.83A96.67,96.67,0,0,0,53.22,6.83,77.19,77.19,0,0,0,49.88,0,105.15,105.15,0,0,0,19.44,8.07C3.66,31.58-1.86,54.65,1,77.53A105.73,105.73,0,0,0,32,96.36a77.7,77.7,0,0,0,6.63-10.85,68.43,68.43,0,0,1-10.5-5c1-.73,2-1.51,2.94-2.31a75.27,75.27,0,0,0,72.13,0c.93.8,1.91,1.58,2.94,2.31a68.43,68.43,0,0,1-10.5,5,77.7,77.7,0,0,0,6.63,10.85,105.73,105.73,0,0,0,31.06-18.83C129,54.65,122.64,31.58,107.7,8.07ZM42.45,65.69C36.18,65.69,31,60,31,53S36.18,40.36,42.45,40.36,53.83,46,53.83,53,48.72,65.69,42.45,65.69Zm42.24,0C78.41,65.69,73.24,60,73.24,53S78.41,40.36,84.69,40.36,96.07,46,96.07,53,91,65.69,84.69,65.69Z"/>
              </svg>
            </a>
          </div>
        </nav>
      </div>
      
      <!-- WIP Alert Bar -->
      <div class="border-t border-white/5 bg-gradient-to-r from-pink-500/10 via-purple-500/5 to-transparent text-xs py-2 text-center text-neutral-300">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-center gap-2 flex-wrap">
          <span class="inline-flex items-center justify-center px-1.5 py-0.5 text-[9px] font-extrabold uppercase tracking-wider rounded bg-pink-500/20 border border-pink-500/30 text-pink-400 font-outfit">
            WIP
          </span>
          <span class="text-neutral-300 text-[11px] sm:text-xs">
            This directory is a work in progress. Currently, only the <a href="/ai-models" class="text-pink-400 hover:text-pink-300 font-semibold underline underline-offset-2 hover:underline-offset-4 transition-all">AI Models</a> section contains real data.
          </span>
        </div>
      </div>
    </header>

    <!-- Main Content Area -->
    <main class="flex-grow">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-white/5 bg-[#09090b] py-8 mt-16 text-center text-xs text-neutral-500">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col items-center gap-2">
        <p>Made with 💖 for the AI community</p>
        <p class="opacity-70">&copy; {new Date().getFullYear()} RPAI Hub. Built with Astro & DaisyUI.</p>
        <p class="opacity-50 text-[10px] mt-1.5">This site does not host any copyrighted files. All links point to external resources.</p>
      </div>
    </footer>

    <!-- Ctrl K Script -->
    <script>
      const searchInput = document.getElementById('global-search') as HTMLInputElement | null;
      document.addEventListener('keydown', (e) => {
        if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
          e.preventDefault();
          searchInput?.focus();
        }
      });
    </script>
  </body>
</html>
